// ============================================================
//  FOG DETECTOR — ESP32 + MPU6050 + Vibration Motor
//  PlatformIO / VS Code
//
//  platformio.ini:
//  [env:esp32dev]
//  platform = espressif32
//  board = esp32dev
//  framework = arduino
//  lib_deps =
//    adafruit/Adafruit MPU6050 @ ^2.2.4
//    adafruit/Adafruit Unified Sensor @ ^1.1.9
//    tanakamasayuki/TensorFlowLite_ESP32 @ ^1.0.0
//  monitor_speed = 115200
// ============================================================

#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_MPU6050.h>
#include <Adafruit_Sensor.h>
#include "tensorflow/lite/micro/micro_error_reporter.h"
#include "TensorFlowLite_ESP32.h"
#include "tensorflow/lite/micro/all_ops_resolver.h"
#include "tensorflow/lite/micro/micro_interpreter.h"
#include "tensorflow/lite/schema/schema_generated.h"
#include "fog_model.h"   // generated by convert_to_tflite.py

// ── Pin definitions ─────────────────────────────────────────
#define MOTOR_PIN     13   // GPIO13 → 1kΩ → Base of NPN transistor
#define SDA_PIN        8
#define SCL_PIN        9
#define LED_PIN        2   // onboard LED, blinks on FOG

// ── Settings ────────────────────────────────────────────────
#define SAMPLE_RATE_HZ    64      // MPU6050 sample rate
#define WINDOW_SIZE       64      // must match training (64 samples = 1 second)
#define NUM_CHANNELS       3      // ax, ay, az only (ankle)
#define FOG_THRESHOLD    0.6f     // confidence needed to trigger alert
#define MOTOR_DURATION   500      // ms to vibrate when FOG detected

// Normalization stats from your training data
// (these are approximate — update with your actual training mean/std)
const float MEAN[3] = { 0.0f,   0.0f,   -950.0f };
const float STD[3]  = { 450.0f, 450.0f,  350.0f };

// ── TFLite setup ────────────────────────────────────────────
const int TENSOR_ARENA_SIZE = 60 * 1024;  // 60KB RAM for model
uint8_t tensor_arena[TENSOR_ARENA_SIZE];

tflite::AllOpsResolver resolver;
tflite::MicroErrorReporter micro_error_reporter;
const tflite::Model* tf_model = nullptr;
tflite::MicroInterpreter* interpreter = nullptr;
TfLiteTensor* input_tensor  = nullptr;
TfLiteTensor* output_tensor = nullptr;

// ── Sensor ──────────────────────────────────────────────────
Adafruit_MPU6050 mpu;

// ── Circular buffer for sliding window ──────────────────────
float window_buf[WINDOW_SIZE][NUM_CHANNELS];
int   buf_idx = 0;
bool  buf_full = false;

// ── Timing ──────────────────────────────────────────────────
unsigned long last_sample_ms = 0;
unsigned long motor_off_ms   = 0;
bool motor_on = false;

// ── Forward declarations ─────────────────────────────────────
void  setup_tflite();
float run_inference();
void  trigger_alert();

// ============================================================
void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("\n=== FOG Detector starting ===");

  // Pins
  pinMode(MOTOR_PIN, OUTPUT);
  pinMode(LED_PIN,   OUTPUT);
  digitalWrite(MOTOR_PIN, LOW);
  digitalWrite(LED_PIN,   LOW);

  // I2C + MPU6050
  Wire.begin(SDA_PIN, SCL_PIN);
  if (!mpu.begin()) {
    Serial.println("ERROR: MPU6050 not found. Check wiring.");
    while (1) { delay(500); }
  }
  mpu.setAccelerometerRange(MPU6050_RANGE_4_G);
  mpu.setGyroRange(MPU6050_RANGE_500_DEG);
  mpu.setFilterBandwidth(MPU6050_BAND_10_HZ);  // low-pass filter
  Serial.println("MPU6050 ready");

  // TFLite
  setup_tflite();
  Serial.println("Model loaded. Collecting data...\n");
}

// ============================================================
void loop() {
  unsigned long now = millis();

  // ── Turn off motor after duration ───────────────────────
  if (motor_on && now >= motor_off_ms) {
    digitalWrite(MOTOR_PIN, LOW);
    digitalWrite(LED_PIN,   LOW);
    motor_on = false;
  }

  // ── Sample at 64 Hz ─────────────────────────────────────
  if (now - last_sample_ms < (1000 / SAMPLE_RATE_HZ)) return;
  last_sample_ms = now;

  sensors_event_t accel, gyro, temp;
  mpu.getEvent(&accel, &gyro, &temp);

  // Store ax, ay, az (in mg — multiply to match DAPHNET units)
  window_buf[buf_idx][0] = accel.acceleration.x * 1000.0f / 9.81f;
  window_buf[buf_idx][1] = accel.acceleration.y * 1000.0f / 9.81f;
  window_buf[buf_idx][2] = accel.acceleration.z * 1000.0f / 9.81f;

  buf_idx = (buf_idx + 1) % WINDOW_SIZE;
  if (buf_idx == 0) buf_full = true;

  // ── Run inference every full window ─────────────────────
  if (!buf_full) return;

  float fog_prob = run_inference();

  Serial.printf("FOG confidence: %.2f  %s\n",
    fog_prob,
    fog_prob >= FOG_THRESHOLD ? "<<< FOG DETECTED >>>" : "normal");

  if (fog_prob >= FOG_THRESHOLD && !motor_on) {
    trigger_alert();
  }
}

// ============================================================
void setup_tflite() {
  tf_model = tflite::GetModel(fog_model);
  if (tf_model->version() != TFLITE_SCHEMA_VERSION) {
    Serial.println("ERROR: TFLite schema version mismatch");
    while (1) {}
  }

  static tflite::MicroInterpreter static_interpreter(
    tf_model, resolver, tensor_arena, TENSOR_ARENA_SIZE, &micro_error_reporter);
  interpreter = &static_interpreter;

  if (interpreter->AllocateTensors() != kTfLiteOk) {
    Serial.println("ERROR: AllocateTensors failed — increase TENSOR_ARENA_SIZE");
    while (1) {}
  }

  input_tensor  = interpreter->input(0);
  output_tensor = interpreter->output(0);

  Serial.printf("Model loaded. Arena used: %d bytes\n",
    interpreter->arena_used_bytes());
}

// ============================================================
float run_inference() {
  // Fill input tensor: shape (1, 3, 64) — channels first
  // Normalize using training stats
  int idx = buf_idx;  // start from oldest sample
  for (int t = 0; t < WINDOW_SIZE; t++) {
    int src = (idx + t) % WINDOW_SIZE;
    for (int ch = 0; ch < NUM_CHANNELS; ch++) {
      float normalized = (window_buf[src][ch] - MEAN[ch]) / STD[ch];
      // Input tensor layout: [channel * WINDOW_SIZE + timestep]
      input_tensor->data.f[ch * WINDOW_SIZE + t] = normalized;
    }
  }

  if (interpreter->Invoke() != kTfLiteOk) {
    Serial.println("ERROR: Inference failed");
    return 0.0f;
  }

  // Output is logits [normal_score, fog_score]
  // Apply softmax manually
  float logit_normal = output_tensor->data.f[0];
  float logit_fog    = output_tensor->data.f[1];
  float max_logit    = max(logit_normal, logit_fog);
  float exp_normal   = exp(logit_normal - max_logit);
  float exp_fog      = exp(logit_fog    - max_logit);
  float fog_prob     = exp_fog / (exp_normal + exp_fog);

  return fog_prob;
}

// ============================================================
void trigger_alert() {
  Serial.println("!!! ALERT: FOG DETECTED — vibrating motor !!!");
  digitalWrite(MOTOR_PIN, HIGH);
  digitalWrite(LED_PIN,   HIGH);
  motor_on    = true;
  motor_off_ms = millis() + MOTOR_DURATION;
}
